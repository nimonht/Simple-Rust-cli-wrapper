# Maintainer: nimonht <nimonht on GitHub>

pkgname=git-workflow
pkgver=0.2.0
pkgrel=1
pkgdesc="A CLI tool that automates Git workflows"
arch=('x86_64')
url="https://github.com/nimonht/Simple-Rust-cli-wrapper"
license=('BSD-2-Clause')
depends=('git' 'github-cli')
makedepends=('rust')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "Simple-Rust-cli-wrapper-${pkgver}"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "Simple-Rust-cli-wrapper-${pkgver}"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release
}

check() {
    cd "Simple-Rust-cli-wrapper-${pkgver}"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo test --frozen
}

package() {
    cd "Simple-Rust-cli-wrapper-${pkgver}"
    install -Dm755 "target/release/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
